{
  "name": "@wb200/mgrep",
  "version": "0.1.12",
  "type": "module",
  "author": "wb200",
  "homepage": "https://github.com/wb200/mgrep",
  "bugs": {
    "url": "https://github.com/wb200/mgrep/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wb200/mgrep.git"
  },
  "main": "dist/index.js",
  "bin": {
    "mgrep": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js && cp -r plugins dist/",
    "dev": "npx tsc && node dist/index.js",
    "test": "bats test/test.bats --filter-tags !long-running",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "semantic-search",
    "embeddings",
    "lancedb",
    "code-search",
    "grep",
    "search"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "description": "Local semantic code search with LanceDB indexing and DeepInfra-powered retrieval",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@lancedb/lancedb": "^0.27.0",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "comment-json": "^4.5.0",
    "ignore": "^7.0.5",
    "istextorbinary": "^9.5.0",
    "openai": "^6.31.0",
    "ora": "^9.3.0",
    "p-limit": "^3.1.0",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "xxhash-wasm": "^1.1.0",
    "yaml": "^2.8.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@types/node": "^24.10.0",
    "bats": "^1.13.0",
    "bats-assert": "github:ztombol/bats-assert",
    "bats-support": "github:ztombol/bats-support",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  }
}
